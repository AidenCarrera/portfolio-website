# Base URL (set per environment)
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=

# Resend API Key (server-only, contact form emails)
RESEND_API_KEY=

# GitHub Personal Access Token (server-only, used for Projects page)
GITHUB_PAT=

# Spotify API (client ID is public-safe, secret is server-only)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
